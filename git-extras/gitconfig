[advice]
  statusHints = false
[color "diff"]
  meta = white dim
  frag = magenta bold
  commit = yellow bold
  old = red bold
  new = green bold
  whitespace = red reverse
[core]
  excludesfile = ~/.gitignore
  pager = delta
[diff]
  colorMoved = default
  tool = delta
[filter "lfs"]
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  process = git-lfs filter-process
  required = true
[format]
  pretty = %Cred%h%Creset%C(yellow)%d%Creset %s %Cgreen(%cd) %C(bold blue)%an %C(yellow)%G?%Creset
[log]
  date = human
[merge]
  conflictstyle = zdiff3
[mergetool]
  keepBackup = false
[push]
  default = simple
[pull]
  rebase = true
[interactive]
  diffFilter = delta --color-only
[delta]
  navigate = true
