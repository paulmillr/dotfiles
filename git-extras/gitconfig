[push]
  default = simple
[pull]
  rebase = true
[log]
  date = human
[format]
  pretty = %Cred%h%Creset%C(yellow)%d%Creset %s %Cgreen(%cd) %C(bold blue)%an %C(yellow)%G?%Creset
[core]
  excludesfile = ~/.gitignore
  pager = delta
  sshCommand = ssh -F /dev/null -o IdentitiesOnly=yes -i ~/.ssh/git
[diff]
  colorMoved = default
  tool = delta
[interactive]
  diffFilter = delta --color-only
[delta]
  navigate = true
[merge]
  conflictstyle = zdiff3
[mergetool]
  keepBackup = false
[color "diff"]
  meta = white dim
  frag = magenta bold
  commit = yellow bold
  old = red bold
  new = green bold
  whitespace = red reverse
[advice]
  statusHints = false
